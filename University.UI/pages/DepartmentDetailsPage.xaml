<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="University.UI.DepartmentDetailsPage"
    Title="Деталі кафедри">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">

            <Label Text="{Binding Name}"
                   FontSize="24"
                   FontAttributes="Bold" />

            <Label Text="{Binding Type}"
                   FontSize="16" />

            <Label Text="{Binding Building}"
                   FontSize="16" />

            <Label Text="Викладачі"
                   FontSize="20"
                   FontAttributes="Bold"
                   Margin="0,12,0,0" />

            <CollectionView ItemsSource="{Binding Teachers}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Padding="12"
                               Margin="0,6"
                               CornerRadius="12">

                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenTeacherCommand}"
                                    CommandParameter="{Binding .}" />
                            </Frame.GestureRecognizers>

                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding FullName}"
                                       FontSize="18"
                                       FontAttributes="Bold" />

                                <Label Text="{Binding Position}"
                                       FontSize="14" />

                                <Label Text="{Binding Email}"
                                       FontSize="14" />
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>