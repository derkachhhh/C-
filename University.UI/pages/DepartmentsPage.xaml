<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="University.UI.DepartmentsPage"
    Title="Кафедри">

    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" Padding="16" RowSpacing="12">

        <Label Grid.Row="0"
               Text="Список кафедр"
               FontSize="24"
               FontAttributes="Bold" />

        <VerticalStackLayout Grid.Row="1" Spacing="8">
            <Entry Placeholder="Пошук кафедри..."
                   Text="{Binding SearchText}" />

            <Picker Title="Сортування"
                    ItemsSource="{Binding SortOptions}"
                    SelectedItem="{Binding SelectedSortOption}" />
        </VerticalStackLayout>

        <HorizontalStackLayout Grid.Row="2" Spacing="12" Wrap="Wrap">
            <Button Text="Додати кафедру"
                    Command="{Binding AddDepartmentCommand}" />

            <Button Text="Редагувати"
                    Command="{Binding EditDepartmentCommand}" />

            <Button Text="Видалити обрану"
                    Command="{Binding DeleteDepartmentCommand}" />
        </HorizontalStackLayout>

        <CollectionView Grid.Row="3"
                        ItemsSource="{Binding Departments}"
                        SelectionMode="Single"
                        SelectedItem="{Binding SelectedDepartment}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Padding="12"
                           Margin="0,6"
                           CornerRadius="12">

                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenDepartmentCommand}"
                                CommandParameter="{Binding .}" />
                        </Frame.GestureRecognizers>

                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding Name}"
                                   FontSize="18"
                                   FontAttributes="Bold" />

                            <Label Text="{Binding Type}"
                                   FontSize="14" />

                            <Label Text="{Binding Building}"
                                   FontSize="14" />
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <ActivityIndicator Grid.Row="4"
                           IsVisible="{Binding IsBusy}"
                           IsRunning="{Binding IsBusy}" />

    </Grid>
</ContentPage>